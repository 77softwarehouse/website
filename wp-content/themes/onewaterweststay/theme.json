{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "ink", "name": "Ink", "color": "#17201d" },
        { "slug": "forest", "name": "Forest", "color": "#243b35" },
        { "slug": "sage", "name": "Sage", "color": "#6f8074" },
        { "slug": "cream", "name": "Cream", "color": "#fbf7ef" },
        { "slug": "bronze", "name": "Bronze", "color": "#a87443" }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1180px"
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
          "name": "Inter/System",
          "slug": "inter"
        },
        {
          "fontFamily": "Georgia, 'Times New Roman', serif",
          "name": "Editorial Serif",
          "slug": "editorial"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#fbf7ef",
      "text": "#17201d"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|inter"
    }
  }
}
